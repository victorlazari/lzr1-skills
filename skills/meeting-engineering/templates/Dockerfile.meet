# Dockerfile.meet — Worker image: Chromium + Xvfb + PulseAudio + Python pipeline.
FROM mcr.microsoft.com/playwright/python:v1.49.0-noble

# tini for PID 1, Xvfb for virtual display, PulseAudio + utils for virtual audio,
# ffmpeg for TTS mp3 decoding, x11-utils for display readiness checks.
RUN apt-get update && apt-get install -y --no-install-recommends \
      tini xvfb pulseaudio pulseaudio-utils ffmpeg x11-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
# requirements typically include: playwright, websockets, pika, psycopg[binary],
# redis (valkey-compatible), httpx, elevenlabs, openai, groq, silero-vad/torch (optional),
# google-api-python-client, google-auth-oauthlib, slack-sdk

# Chromium is bundled in the Playwright base image; ensure browsers are present.
RUN playwright install chromium

COPY . .
RUN chmod +x /app/meet-entrypoint.sh /app/setup_pulse_devices.sh

# Non-root user: PulseAudio refuses to run as root by default.
RUN useradd -m -u 1001 meetbot && chown -R meetbot:meetbot /app /tmp
USER meetbot

ENV DISPLAY=:99 \
    PULSE_SERVER=unix:/tmp/pulse-socket

ENTRYPOINT ["/usr/bin/tini", "--", "/app/meet-entrypoint.sh"]
CMD ["python", "-m", "meet_worker"]
